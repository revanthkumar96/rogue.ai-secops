{
  "$schema": "https://json.schemastore.org/package.json",
  "version": "0.1.0",
  "name": "rouge",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "prepare": "bun run build || true",
    "typecheck": "tsc --noEmit",
    "test": "bun test --timeout 30000",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:integration": "bun test src/test/cli.test.ts --timeout 60000",
    "test:unit": "bun test src/test/agent.test.ts src/test/skill.test.ts src/test/ability.test.ts src/test/config.test.ts",
    "test:provider": "bun test src/test/provider.test.ts --timeout 30000",
    "test:tool": "bun test src/test/tool.test.ts",
    "test:ci": "bun test --coverage --timeout 60000",
    "build": "echo 'Build not yet implemented'",
    "dev": "bun run --watch ./src/index.ts"
  },
  "bin": {
    "rouge": "./bin/rouge"
  },
  "exports": {
    "./*": "./src/*.ts"
  },
  "dependencies": {
    "@rouge/shared": "workspace:*",
    "hono": "catalog:",
    "@hono/zod-validator": "^0.4.1",
    "drizzle-orm": "catalog:",
    "better-sqlite3": "^11.7.0",
    "xdg-basedir": "^5.1.0",
    "zod": "catalog:",
    "yargs": "^18.0.0",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/bun": "catalog:",
    "@types/yargs": "^17.0.33",
    "@tsconfig/bun": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
